{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "Salah Uddin Selim",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "analyze": "ANALYZE=true next build",
    "knip": "knip",
    "sanity": "sanity dev",
    "lhci": "npm run build && lhci autorun --upload.target=temporary-public-storage --start-server-command=\"npm run start -- --hostname 127.0.0.1 --port 3000\" --start-server-ready-pattern=\"Ready in\" --start-server-ready-timeout=20000 --collect.settings.chromeFlags=\"--headless --disable-gpu --no-sandbox --disable-dev-shm-usage\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{mjs,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@sanity/image-url": "^2.1.1",
    "@upstash/ratelimit": "^2.0.3",
    "@upstash/redis": "^1.34.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.10",
    "next-sanity": "^13.0.8",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "resend": "^6.14.0",
    "sanity": "^6.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "knip": "^5.56.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.1.3"
  },
  "browserslist": [
    "since 2024-01",
    "not dead",
    "not IE 11",
    "not op_mini all"
  ]
}
