{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:3000/"],
      "numberOfRuns": 1,
      "settings": {
        "formFactor": "mobile",
        "throttlingMethod": "devtools",
        "throttling": {
          "cpuSlowdownMultiplier": 4,
          "rttMs": 150,
          "downloadThroughputKbps": 1200,
          "uploadThroughputKbps": 600
        }
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
