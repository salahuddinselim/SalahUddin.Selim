# ─── Sanity CMS ─────────────────────────────────────────────
# Find these in your Sanity project dashboard → API
NEXT_PUBLIC_SANITY_PROJECT_ID=id5e9a8v
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_TOKEN=your_sanity_api_token
# Shared secret for the /api/revalidate webhook — set the same value in
# Sanity project settings → API → Webhooks, so content changes go live
# immediately instead of waiting for the hourly ISR revalidation.
SANITY_REVALIDATE_SECRET=your_revalidate_webhook_secret

# ─── AI Chat (Infernape) ───────────────────────────────────
# At least one must be set. Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_gemini_api_key

# ─── Email (Contact Form via Resend) ───────────────────────
# Optional — without these, messages log to console
# Get keys at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=your_email@example.com

# ─── Turnstile (CAPTCHA) ───────────────────────────────────
# Get both keys from Cloudflare dashboard → Turnstile
NEXT_PUBLIC_TURNSTILE_SITEKEY=your_turnstile_sitekey
TURNSTILE_SECRET_KEY=your_turnstile_secret

# ─── Site URL ──────────────────────────────────────────────
# Override auto-detection for sitemap, OG images, canonical URLs
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─── Rate Limiting (Optional — falls back to in-memory) ────
# Sign up at https://upstash.com for a free Redis instance
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io/redis/xxx
# UPSTASH_REDIS_REST_TOKEN=your_token

# ─── Auth (Reserved for future admin area) ─────────────────
# Generate: openssl rand -base64 32
# Must be at least 32 characters in production
# SESSION_SECRET=your-secret-at-least-32-characters-long

# ─── Vercel (Auto-set by Vercel; include locally for parity) ──
# VERCEL_ENV=development
# VERCEL_URL=localhost:3000
